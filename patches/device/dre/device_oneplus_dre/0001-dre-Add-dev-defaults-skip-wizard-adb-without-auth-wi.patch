From dc1d251a5b2df81bd28c5a72223adfc4d6a25399 Mon Sep 17 00:00:00 2001
From: psyclyx <me@psyclyx.xyz>
Date: Wed, 1 Apr 2026 04:29:15 -0700
Subject: [PATCH] dre: Add dev defaults - skip wizard, adb without auth, wifi
 auto-setup

Skip the setup wizard, enable adb without authorization prompt, and
add an init service that auto-configures wifi on first boot from a
gitignored credentials file (dev-defaults/wifi-setup.sh).
---
 .gitignore                |  2 ++
 device.mk                 |  9 +++++++++
 init/init.dev-defaults.rc | 11 +++++++++++
 3 files changed, 22 insertions(+)
 create mode 100644 .gitignore
 create mode 100644 init/init.dev-defaults.rc

diff --git a/.gitignore b/.gitignore
new file mode 100644
index 0000000..e5c6b22
--- /dev/null
+++ b/.gitignore
@@ -0,0 +1,2 @@
+# Local dev config (wifi creds, etc.)
+dev-defaults/
diff --git a/device.mk b/device.mk
index 88beb77..7b31201 100644
--- a/device.mk
+++ b/device.mk
@@ -423,5 +423,14 @@ PRODUCT_PACKAGES += \
     firmware_wlan_mac.bin_symlink \
     firmware_WCNSS_qcom_cfg.ini_symlink
 
+# Dev defaults: skip setup wizard, enable adb without auth
+PRODUCT_SYSTEM_DEFAULT_PROPERTIES += \
+    ro.setupwizard.mode=OPTIONAL \
+    persist.sys.usb.config=mtp,adb \
+    ro.adb.secure=0
+
+# Dev defaults: auto wifi setup (gitignored, contains credentials)
+-include $(LOCAL_PATH)/dev-defaults/dev-defaults.mk
+
 # Get non-open-source specific aspects
 $(call inherit-product, vendor/oneplus/dre/dre-vendor.mk)
diff --git a/init/init.dev-defaults.rc b/init/init.dev-defaults.rc
new file mode 100644
index 0000000..2ac2cd2
--- /dev/null
+++ b/init/init.dev-defaults.rc
@@ -0,0 +1,11 @@
+# Dev defaults - skip wizard, enable adb, auto-configure wifi
+on property:sys.boot_completed=1
+    start dev_wifi_setup
+
+service dev_wifi_setup /system/bin/sh /system/etc/dev-defaults/wifi-setup.sh
+    class late_start
+    user root
+    group root wifi
+    oneshot
+    disabled
+    seclabel u:r:shell:s0
-- 
2.53.0

