From a31b2db3b141888f681d3106268c15aecf5a5318 Mon Sep 17 00:00:00 2001
From: psyclyx <me@psyclyx.xyz>
Date: Wed, 1 Apr 2026 04:28:59 -0700
Subject: [PATCH] touch: Copy msm_drm.dsi_display0 to tp_dsi_display_primary

The bootloader passes the panel name via msm_drm.dsi_display0 but the
Oplus touch driver reads from oplus_bsp_tp_custom.dsi_display0 which
is never set by the bootloader. Use a core_initcall to parse
saved_command_line and copy the value so the touch IC is matched.

Also add a fallback for get_project() to parse
androidboot.prj_version from the cmdline when SMEM_PROJECT is
unavailable, which happens on LineageOS.
---
 .../input/touchscreen/touch_custom/touch.c    | 30 +++++++++++++++++++
 .../system/oplus_project/qcom/oplus_project.c | 28 ++++++++++++++++-
 2 files changed, 57 insertions(+), 1 deletion(-)

diff --git a/drivers/input/touchscreen/touch_custom/touch.c b/drivers/input/touchscreen/touch_custom/touch.c
index e4a39e3e69e1..356fc9dd8ca4 100644
--- a/drivers/input/touchscreen/touch_custom/touch.c
+++ b/drivers/input/touchscreen/touch_custom/touch.c
@@ -166,6 +166,36 @@ module_param_string(dsi_display0, tp_dsi_display_primary, MAX_CMDLINE_PARAM_LEN,
                     0600);
 MODULE_PARM_DESC(dsi_display0,
                  "oplus_bsp_tp_custom.dsi_display0=<display node> for primary dsi display node name");
+
+/*
+ * The bootloader passes the panel name via msm_drm.dsi_display0 but this
+ * built-in driver reads from oplus_bsp_tp_custom.dsi_display0 which the
+ * bootloader never sets.  Copy the value so the touch IC is matched.
+ */
+static int __init tp_copy_msm_drm_dsi(void)
+{
+	char *val;
+
+	if (tp_dsi_display_primary[0])
+		return 0;
+
+	val = strstr(saved_command_line, "msm_drm.dsi_display0=");
+	if (val) {
+		char *end;
+
+		val += strlen("msm_drm.dsi_display0=");
+		end = strchrnul(val, ' ');
+		if (end - val < MAX_CMDLINE_PARAM_LEN) {
+			memcpy(tp_dsi_display_primary, val, end - val);
+			tp_dsi_display_primary[end - val] = '\0';
+			pr_info("[TP] Copied msm_drm.dsi_display0 -> tp_dsi_display_primary = %s\n",
+				tp_dsi_display_primary);
+		}
+	}
+	return 0;
+}
+core_initcall(tp_copy_msm_drm_dsi);
+
 module_param_string(dsi_display1, tp_dsi_display_secondary, MAX_CMDLINE_PARAM_LEN,
                     0600);
 MODULE_PARM_DESC(dsi_display1,
diff --git a/drivers/soc/oplus/system/oplus_project/qcom/oplus_project.c b/drivers/soc/oplus/system/oplus_project/qcom/oplus_project.c
index 3e13423002c6..3db43a2de4b9 100644
--- a/drivers/soc/oplus/system/oplus_project/qcom/oplus_project.c
+++ b/drivers/soc/oplus/system/oplus_project/qcom/oplus_project.c
@@ -185,11 +185,37 @@ static int __init cdt_setup(char *str)
 }
 __setup("cdt_integrity=", cdt_setup);
 
+static unsigned int cmdline_project_no;
+static bool cmdline_project_parsed;
+
+static unsigned int get_project_from_cmdline(void)
+{
+    char *val;
+
+    if (cmdline_project_parsed)
+        return cmdline_project_no;
+
+    cmdline_project_parsed = true;
+    val = strstr(saved_command_line, "androidboot.prj_version=");
+    if (val) {
+        unsigned int prj = 0;
+        val += strlen("androidboot.prj_version=");
+        if (sscanf(val, "%u", &prj) == 1) {
+            cmdline_project_no = prj;
+            pr_info("get_project: using cmdline prj_version=%u\n", prj);
+        }
+    }
+    return cmdline_project_no;
+}
+
 unsigned int get_project(void)
 {
     init_project_version();
 
-    return g_project? g_project->nDataBCDT.ProjectNo : 0;
+    if (g_project)
+        return g_project->nDataBCDT.ProjectNo;
+
+    return get_project_from_cmdline();
 }
 EXPORT_SYMBOL(get_project);
 
-- 
