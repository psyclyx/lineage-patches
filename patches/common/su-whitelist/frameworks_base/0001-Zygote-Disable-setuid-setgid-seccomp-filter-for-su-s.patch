From cd125e3468dbbc8d360dda2acac822eb6abe6e05 Mon Sep 17 00:00:00 2001
From: psyclyx <me@psyclyx.xyz>
Date: Wed, 1 Apr 2026 22:16:58 -0700
Subject: [PATCH] Zygote: Disable setuid/setgid seccomp filter for su support

The setuid/setgid seccomp filter prevents apps from calling
setuid(0) even after transitioning to the su SELinux domain.
Disable this filter so the su binary can elevate privileges.
Access control is enforced by su's UID whitelist instead.

Change-Id: Ib8aba017554d7b96596ca829d058a2530ee85d5e
---
 core/jni/com_android_internal_os_Zygote.cpp | 13 ++++---------
 1 file changed, 4 insertions(+), 9 deletions(-)

diff --git a/core/jni/com_android_internal_os_Zygote.cpp b/core/jni/com_android_internal_os_Zygote.cpp
index a92c6c8718ee..418a73e0259d 100644
--- a/core/jni/com_android_internal_os_Zygote.cpp
+++ b/core/jni/com_android_internal_os_Zygote.cpp
@@ -2780,15 +2780,10 @@ static void com_android_internal_os_Zygote_nativeAllowFileAcrossFork(
 
 static void com_android_internal_os_Zygote_nativeInstallSeccompUidGidFilter(
         JNIEnv* env, jclass, jint uidGidMin, jint uidGidMax) {
-  if (!gIsSecurityEnforced) {
-    ALOGI("seccomp disabled by setenforce 0");
-    return;
-  }
-
-  bool installed = install_setuidgid_seccomp_filter(uidGidMin, uidGidMax);
-  if (!installed) {
-      RuntimeAbort(env, __LINE__, "Could not install setuid/setgid seccomp filter.");
-  }
+  // Disabled: the setuid/setgid seccomp filter prevents su from working.
+  // Access control for su is handled by the su binary's UID whitelist.
+  (void)env; (void)uidGidMin; (void)uidGidMax;
+  return;
 }
 
 /**
