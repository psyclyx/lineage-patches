From 0cf2f67e89e188dec646032005359f306eefa26e Mon Sep 17 00:00:00 2001
From: psyclyx <me@psyclyx.xyz>
Date: Fri, 3 Apr 2026 00:29:17 -0700
Subject: [PATCH] sepolicy: Allow su daemon socket connections from apps

Add SELinux rules for the su daemon:
- Allow init to start su daemon (getattr/read/open/execute su_exec)
- Allow su domain to create/bind/listen/accept on unix_stream_socket
- Allow untrusted_app variants to connect to su daemon socket

Change-Id: I874b32b1869aa3212010a0f06a6c8e15763330b2
---
 private/domain.te |  2 +-
 private/su.te     | 16 ++++++++++++++++
 2 files changed, 17 insertions(+), 1 deletion(-)

diff --git a/private/domain.te b/private/domain.te
index 054014f53..29c0e8ddb 100644
--- a/private/domain.te
+++ b/private/domain.te
@@ -1369,7 +1369,7 @@ neverallow {
 # Nobody should be able to execute su on user builds.
 # On userdebug/eng builds, only dumpstate, shell, su, and
 # whitelisted app domains execute su.
-neverallow { domain -init -dumpstate -shell -su -overlay_remounter -untrusted_app -untrusted_app_25 -untrusted_app_27 -untrusted_app_29 -untrusted_app_30 -untrusted_app_32 } su_exec:file no_x_file_perms;
+neverallow { domain -init -dumpstate -shell -su -overlay_remounter -system_app -untrusted_app -untrusted_app_25 -untrusted_app_27 -untrusted_app_29 -untrusted_app_30 -untrusted_app_32 } su_exec:file no_x_file_perms;
 
 # Do not allow the introduction of new execmod rules. Text relocations
 # and modification of executable pages are unsafe.
diff --git a/private/su.te b/private/su.te
index d84ad7d3d..d08ba7632 100644
--- a/private/su.te
+++ b/private/su.te
@@ -10,10 +10,26 @@ domain_auto_trans(untrusted_app_27, su_exec, su)
 domain_auto_trans(untrusted_app_29, su_exec, su)
 domain_auto_trans(untrusted_app_30, su_exec, su)
 domain_auto_trans(untrusted_app_32, su_exec, su)
+domain_auto_trans(system_app, su_exec, su)
 
 # Allow su to re-exec itself (to escape app seccomp filter)
 allow su su_exec:file { read open getattr execute execute_no_trans };
 
+# Allow init to start su daemon service
+allow init su_exec:file { getattr open read execute };
+
+# Allow su daemon to create and listen on its socket
+allow su su:unix_stream_socket { create bind listen accept read write getattr setopt };
+
+# Allow apps to connect to the su daemon socket
+allow untrusted_app su:unix_stream_socket connectto;
+allow untrusted_app_25 su:unix_stream_socket connectto;
+allow untrusted_app_27 su:unix_stream_socket connectto;
+allow untrusted_app_29 su:unix_stream_socket connectto;
+allow untrusted_app_30 su:unix_stream_socket connectto;
+allow untrusted_app_32 su:unix_stream_socket connectto;
+allow system_app su:unix_stream_socket connectto;
+
 # su is permissive — access control is in the su binary, not SELinux
 permissive su;
 
-- 
2.53.0

