From 9e3a722c205cc94b4501b1d09d370cbc88a9429a Mon Sep 17 00:00:00 2001
From: psyclyx <me@psyclyx.xyz>
Date: Wed, 1 Apr 2026 04:49:58 -0700
Subject: [PATCH] sepolicy: Enable su for all build variants with app
 transitions

Move su domain setup out of userdebug_or_eng() wrapper so su works
on user builds. Add domain transitions for all untrusted_app variants.
Access control is enforced by the su binary's UID whitelist.

Change-Id: I905deb70afadf4d4db2d78cd08ef28707cdda7dc
---
 private/su.te | 40 ++++++++++++++++++++++++----------------
 1 file changed, 24 insertions(+), 16 deletions(-)

diff --git a/private/su.te b/private/su.te
index fae9b987e..042f657da 100644
--- a/private/su.te
+++ b/private/su.te
@@ -1,7 +1,28 @@
-userdebug_or_eng(`
-  typeattribute su coredomain;
+# Whitelisted su: allow all builds to use su (access control in userspace)
+typeattribute su coredomain;
+
+domain_auto_trans(shell, su_exec, su)
+
+# Allow apps to execute su (whitelist enforced by su binary itself)
+domain_auto_trans(untrusted_app, su_exec, su)
+domain_auto_trans(untrusted_app_25, su_exec, su)
+domain_auto_trans(untrusted_app_27, su_exec, su)
+domain_auto_trans(untrusted_app_29, su_exec, su)
+domain_auto_trans(untrusted_app_30, su_exec, su)
+domain_auto_trans(untrusted_app_32, su_exec, su)
+
+# Allow su to read its whitelist
+allow su system_data_file:file { read open getattr };
+
+# su is permissive — access control is in the su binary, not SELinux
+permissive su;
+
+app_domain(su)
+typeattribute su mlstrustedsubject;
+net_domain(su)
+vndbinder_use(su)
 
-  domain_auto_trans(shell, su_exec, su)
+userdebug_or_eng(`
   # Allow dumpstate to call su on userdebug / eng builds to collect
   # additional information.
   domain_auto_trans(dumpstate, su_exec, su)
@@ -23,22 +44,9 @@ userdebug_or_eng(`
   # own domain.
   virtualizationservice_use(su)
 
-  # su is also permissive to permit setenforce.
-  permissive su;
-
-  app_domain(su)
-
   # Do not audit accesses to keystore2 namespace for the su domain.
   dontaudit su keystore2_key_type:{ keystore2 keystore2_key } *;
 
-  typeattribute su mlstrustedsubject;
-
-  # Add su to various domains
-  net_domain(su)
-
-  # grant su access to vndbinder
-  vndbinder_use(su)
-
   dontaudit su self:capability_class_set *;
   dontaudit su self:capability2 *;
   dontaudit su kernel:security *;
-- 
2.53.0

