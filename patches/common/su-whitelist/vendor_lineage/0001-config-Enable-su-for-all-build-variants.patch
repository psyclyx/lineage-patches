From d4f1e4ce3c8c7242cb58a57d35db3c7991d2ff0a Mon Sep 17 00:00:00 2001
From: psyclyx <me@psyclyx.xyz>
Date: Wed, 1 Apr 2026 05:34:42 -0700
Subject: [PATCH] config: Enable su for all build variants

Remove user-build restriction on WITH_SU. Access control is handled
by the su binary's per-app whitelist, not the build variant.

Change-Id: I8d85354db6dc25f580ada9f138ec9b6b70de393d
---
 config/common.mk | 3 +--
 1 file changed, 1 insertion(+), 2 deletions(-)

diff --git a/config/common.mk b/config/common.mk
index b961788f..89097524 100644
--- a/config/common.mk
+++ b/config/common.mk
@@ -234,7 +234,7 @@ endif
 # Root
 PRODUCT_PACKAGES += \
     adb_root
-ifneq ($(TARGET_BUILD_VARIANT),user)
+WITH_SU := true
 ifeq ($(WITH_SU),true)
 PRODUCT_PACKAGES += \
     su
@@ -242,7 +242,6 @@ PRODUCT_PACKAGES += \
 PRODUCT_ARTIFACT_PATH_REQUIREMENT_ALLOWED_LIST += \
     system/xbin/su
 endif
-endif
 
 # SystemUI
 PRODUCT_DEXPREOPT_SPEED_APPS += \
-- 
2.53.0

