From a9be9119dbe57d9d97ddfafa3baa0dad0a4124a6 Mon Sep 17 00:00:00 2001
From: psyclyx <me@psyclyx.xyz>
Date: Wed, 1 Apr 2026 05:34:42 -0700
Subject: [PATCH] config: Enable su for all build variants

Set WITH_SU=true and remove user-build restriction.
Access control handled by su binary's per-app whitelist.

Change-Id: I9ce62c42ba4d5022ebc2cf6520bcc64fb6375619
---
 config/common.mk | 5 ++---
 1 file changed, 2 insertions(+), 3 deletions(-)

diff --git a/config/common.mk b/config/common.mk
index b961788f..466aabdf 100644
--- a/config/common.mk
+++ b/config/common.mk
@@ -234,14 +234,13 @@ endif
 # Root
 PRODUCT_PACKAGES += \
     adb_root
-ifneq ($(TARGET_BUILD_VARIANT),user)
+WITH_SU := true
 ifeq ($(WITH_SU),true)
 PRODUCT_PACKAGES += \
     su
 
 PRODUCT_ARTIFACT_PATH_REQUIREMENT_ALLOWED_LIST += \
-    system/xbin/su
-endif
+    system/bin/su
 endif
 
 # SystemUI
