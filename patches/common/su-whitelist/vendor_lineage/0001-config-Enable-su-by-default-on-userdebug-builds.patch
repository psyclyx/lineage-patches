From 17accbc4601af7bca6a8f26283bf95e778c9796d Mon Sep 17 00:00:00 2001
From: psyclyx <me@psyclyx.xyz>
Date: Wed, 1 Apr 2026 04:49:50 -0700
Subject: [PATCH] config: Enable su by default on userdebug builds

Set WITH_SU=true so the su binary is included in userdebug builds.
Per-app access control is handled by the whitelist in su itself.

Change-Id: I6de0c48078352f494e48a7e85bef151aefe2bcfd
---
 config/common.mk | 1 +
 1 file changed, 1 insertion(+)

diff --git a/config/common.mk b/config/common.mk
index b961788f..1d3771f3 100644
--- a/config/common.mk
+++ b/config/common.mk
@@ -235,6 +235,7 @@ endif
 PRODUCT_PACKAGES += \
     adb_root
 ifneq ($(TARGET_BUILD_VARIANT),user)
+WITH_SU := true
 ifeq ($(WITH_SU),true)
 PRODUCT_PACKAGES += \
     su
-- 
2.53.0

