+package com.android.settings.development;
+
+import android.content.Context;
+
+import com.android.settings.core.PreferenceControllerMixin;
+import com.android.settingslib.development.DeveloperOptionsPreferenceController;
+
+public class SuAccessPreferenceController extends DeveloperOptionsPreferenceController
+        implements PreferenceControllerMixin {
+
+    private static final String PREF_KEY = "su_access_settings";
+
+    public SuAccessPreferenceController(Context context) {
+        super(context);
+    }
+
+    @Override
+    public String getPreferenceKey() {
+        return PREF_KEY;
+    }
+
+    @Override
+    public boolean isAvailable() {
+        return true;
+    }
+}
diff --git a/src/com/android/settings/development/su/SuAccessFragment.java b/src/com/android/settings/development/su/SuAccessFragment.java
new file mode 100644
index 00000000000..e3f09276cfd
--- /dev/null
+++ b/src/com/android/settings/development/su/SuAccessFragment.java
@@ -0,0 +1,175 @@
+/*
+ * SPDX-License-Identifier: Apache-2.0
+ */
+
+package com.android.settings.development.su;
+
+import android.content.pm.ApplicationInfo;
+import android.content.pm.PackageManager;
+import android.os.Bundle;
+import android.util.Log;
+import android.view.Menu;
+import android.view.MenuInflater;
+import android.view.MenuItem;
+
+import androidx.preference.PreferenceCategory;
+import androidx.preference.PreferenceScreen;
+import androidx.preference.SwitchPreferenceCompat;
+
+import com.android.settings.R;
+import com.android.settings.SettingsPreferenceFragment;
+
+import java.io.BufferedReader;
+import java.io.File;
+import java.io.FileOutputStream;
+import java.io.FileReader;
+import java.io.IOException;
+import java.io.PrintWriter;
+import java.util.Collections;
+import java.util.HashSet;
+import java.util.List;
+import java.util.Set;
+
+public class SuAccessFragment extends SettingsPreferenceFragment {
+    private static final String TAG = "SuAccessFragment";
+    // World-readable file so su binary can read it without root.
+    // su runs in the su SELinux domain but inherits the caller's UID
+    // and seccomp filter, so it can't setuid or query system services.
+    private static final String WHITELIST_PATH = "/data/local/su_whitelist";
+    private static final String KEY_SHOW_SYSTEM = "show_system";
+    private static final int MENU_SHOW_SYSTEM = Menu.FIRST;
+
+    private PackageManager mPm;
+    private Set<Integer> mWhitelisted;
+    private boolean mShowSystem;
+
+    @Override
+    public int getMetricsCategory() {
+        return 0;
+    }
+
+    @Override
+    public void onCreate(Bundle savedInstanceState) {
+        super.onCreate(savedInstanceState);
+        mPm = getActivity().getPackageManager();
+        mWhitelisted = readWhitelist();
+        if (savedInstanceState != null) {
+            mShowSystem = savedInstanceState.getBoolean(KEY_SHOW_SYSTEM, false);
+        }
+        setHasOptionsMenu(true);
+        buildAppList();
+    }
+
+    @Override
+    public void onSaveInstanceState(Bundle outState) {
+        super.onSaveInstanceState(outState);
+        outState.putBoolean(KEY_SHOW_SYSTEM, mShowSystem);
+    }
+
+    @Override
+    public void onCreateOptionsMenu(Menu menu, MenuInflater inflater) {
+        menu.add(Menu.NONE, MENU_SHOW_SYSTEM, Menu.NONE,
+                mShowSystem ? R.string.menu_hide_system : R.string.menu_show_system);
+        super.onCreateOptionsMenu(menu, inflater);
+    }
+
+    @Override
+    public boolean onOptionsItemSelected(MenuItem item) {
+        if (item.getItemId() == MENU_SHOW_SYSTEM) {
+            mShowSystem = !mShowSystem;
+            item.setTitle(mShowSystem ? R.string.menu_hide_system : R.string.menu_show_system);
+            buildAppList();
+            return true;
+        }
+        return super.onOptionsItemSelected(item);
+    }
+
+    private void buildAppList() {
+        PreferenceScreen screen = getPreferenceManager().createPreferenceScreen(getActivity());
+        setPreferenceScreen(screen);
+
+        List<ApplicationInfo> apps = mPm.getInstalledApplications(0);
+
+        Collections.sort(apps, (a, b) -> {
+            String la = mPm.getApplicationLabel(a).toString();
+            String lb = mPm.getApplicationLabel(b).toString();
+            return la.compareToIgnoreCase(lb);
+        });
+
+        char lastSection = 0;
+        PreferenceCategory currentCategory = null;
+
+        for (ApplicationInfo app : apps) {
+            boolean hasLauncher = mPm.getLaunchIntentForPackage(app.packageName) != null;
+            if (!hasLauncher && !mShowSystem) continue;
+
+            String label = mPm.getApplicationLabel(app).toString();
+            char section = Character.toUpperCase(label.charAt(0));
+            if (!Character.isLetter(section)) section = '#';
+
+            if (section != lastSection) {
+                lastSection = section;
+                currentCategory = new PreferenceCategory(getActivity());
+                currentCategory.setTitle(String.valueOf(section));
+                screen.addPreference(currentCategory);
+            }
+
+            SwitchPreferenceCompat pref = new SwitchPreferenceCompat(getActivity());
+            pref.setTitle(label);
+            pref.setSummary(app.packageName);
+            pref.setIcon(mPm.getApplicationIcon(app));
+            pref.setChecked(mWhitelisted.contains(app.uid));
+            final int uid = app.uid;
+            pref.setOnPreferenceChangeListener((preference, newValue) -> {
+                if ((Boolean) newValue) {
+                    mWhitelisted.add(uid);
+                } else {
+                    mWhitelisted.remove(uid);
+                }
+                writeWhitelist(mWhitelisted);
+                return true;
+            });
+            currentCategory.addPreference(pref);
+        }
+    }
+
+    private Set<Integer> readWhitelist() {
+        Set<Integer> uids = new HashSet<>();
+        File f = new File(WHITELIST_PATH);
+        if (!f.exists()) return uids;
+
+        try (BufferedReader reader = new BufferedReader(new FileReader(f))) {
+            String line;
+            while ((line = reader.readLine()) != null) {
+                line = line.trim();
+                if (!line.isEmpty()) {
+                    try {
+                        uids.add(Integer.parseInt(line));
+                    } catch (NumberFormatException e) {
+                        // skip
+                    }
+                }
+            }
+        } catch (IOException e) {
+            Log.e(TAG, "Failed to read whitelist", e);
+        }
+        return uids;
+    }
+
+    private void writeWhitelist(Set<Integer> uids) {
+        try {
+            File f = new File(WHITELIST_PATH);
+            try (PrintWriter writer = new PrintWriter(new FileOutputStream(f))) {
+                for (int uid : uids) {
+                    writer.println(uid);
+                }
+            }
+            // World-readable so su binary can check it from any UID
+            f.setReadable(true, false);
+            f.setWritable(false, false);
+            f.setWritable(true, true);
+        } catch (IOException e) {
+            Log.e(TAG, "Failed to write whitelist", e);
+        }
+    }
+}
