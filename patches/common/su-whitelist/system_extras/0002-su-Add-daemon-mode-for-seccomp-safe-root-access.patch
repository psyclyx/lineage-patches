-void pwtoid(const char* tok, uid_t* uid, gid_t* gid) {
+/* ------------------------------------------------------------------ */
+/* Helpers: send/receive file descriptors over Unix socket             */
+/* ------------------------------------------------------------------ */
+
+static int send_fds(int sock, const int* fds, int nfds) {
+    char dummy = 'F';
+    struct iovec iov = { .iov_base = &dummy, .iov_len = 1 };
+
+    char cmsg_buf[CMSG_SPACE(sizeof(int) * 3)];
+    struct msghdr msg = {};
+    msg.msg_iov = &iov;
+    msg.msg_iovlen = 1;
+    msg.msg_control = cmsg_buf;
+    msg.msg_controllen = CMSG_SPACE(sizeof(int) * nfds);
+
+    struct cmsghdr* cmsg = CMSG_FIRSTHDR(&msg);
+    cmsg->cmsg_level = SOL_SOCKET;
+    cmsg->cmsg_type = SCM_RIGHTS;
+    cmsg->cmsg_len = CMSG_LEN(sizeof(int) * nfds);
+    memcpy(CMSG_DATA(cmsg), fds, sizeof(int) * nfds);
+
+    return sendmsg(sock, &msg, 0) >= 0 ? 0 : -1;
+}
+
+static int recv_fds(int sock, int* fds, int nfds) {
+    char dummy;
+    struct iovec iov = { .iov_base = &dummy, .iov_len = 1 };
+
+    char cmsg_buf[CMSG_SPACE(sizeof(int) * 3)];
+    struct msghdr msg = {};
+    msg.msg_iov = &iov;
+    msg.msg_iovlen = 1;
+    msg.msg_control = cmsg_buf;
+    msg.msg_controllen = sizeof(cmsg_buf);
+
+    if (recvmsg(sock, &msg, 0) < 0) return -1;
+
+    struct cmsghdr* cmsg = CMSG_FIRSTHDR(&msg);
+    if (!cmsg || cmsg->cmsg_level != SOL_SOCKET || cmsg->cmsg_type != SCM_RIGHTS)
+        return -1;
+
+    memcpy(fds, CMSG_DATA(cmsg), sizeof(int) * nfds);
+    return 0;
+}
+
+/* Read exactly n bytes. */
+static bool read_full(int fd, void* buf, size_t n) {
+    char* p = (char*)buf;
+    while (n > 0) {
+        ssize_t r = read(fd, p, n);
+        if (r <= 0) return false;
+        p += r;
+        n -= r;
+    }
+    return true;
+}
+
+/* Write exactly n bytes. */
+static bool write_full(int fd, const void* buf, size_t n) {
+    const char* p = (const char*)buf;
+    while (n > 0) {
+        ssize_t r = write(fd, p, n);
+        if (r <= 0) return false;
+        p += r;
+        n -= r;
+    }
+    return true;
+}
+
+/* ------------------------------------------------------------------ */
+/* Request wire format:                                                */
+/*   uint32_t target_uid                                               */
+/*   uint32_t target_gid                                               */
+/*   uint32_t argc                                                     */
+/*   For each arg: uint32_t len, then len bytes (no NUL)               */
+/* ------------------------------------------------------------------ */
+
+/* ------------------------------------------------------------------ */
+/* Daemon                                                              */
+/* ------------------------------------------------------------------ */
+
+static void handle_client(int client_fd) {
+    /* Get caller credentials */
+    struct ucred cred;
+    socklen_t cred_len = sizeof(cred);
+    if (getsockopt(client_fd, SOL_SOCKET, SO_PEERCRED, &cred, &cred_len) < 0) {
+        fprintf(stderr, "su: daemon: failed to get peer credentials: %s\n", strerror(errno));
+        uint32_t exit_code = 1;
+        write_full(client_fd, &exit_code, sizeof(exit_code));
+        close(client_fd);
+        return;
+    }
+
+    /* Check whitelist */
+    if (!uid_is_whitelisted(cred.uid)) {
+        fprintf(stderr, "su: daemon: uid %u not whitelisted\n", cred.uid);
+        uint32_t exit_code = 1;
+        write_full(client_fd, &exit_code, sizeof(exit_code));
+        close(client_fd);
+        return;
+    }
+
+    /* Receive stdin/stdout/stderr fds */
+    int fds[3];
+    if (recv_fds(client_fd, fds, 3) < 0) {
+        fprintf(stderr, "su: daemon: failed to receive fds\n");
+        uint32_t exit_code = 1;
+        write_full(client_fd, &exit_code, sizeof(exit_code));
+        close(client_fd);
+        return;
+    }
+
+    /* Read request header */
+    uint32_t target_uid, target_gid, argc;
+    if (!read_full(client_fd, &target_uid, 4) ||
+        !read_full(client_fd, &target_gid, 4) ||
+        !read_full(client_fd, &argc, 4)) {
+        fprintf(stderr, "su: daemon: failed to read request\n");
+        goto fail_fds;
+    }
+
+    if (argc > 1024) goto fail_fds;
+
+    {
+        /* Read arguments */
+        char** args = (char**)calloc(argc + 1, sizeof(char*));
+        for (uint32_t i = 0; i < argc; i++) {
+            uint32_t len;
+            if (!read_full(client_fd, &len, 4) || len > MAX_REQUEST_SIZE) {
+                for (uint32_t j = 0; j < i; j++) free(args[j]);
+                free(args);
+                goto fail_fds;
+            }
+            args[i] = (char*)malloc(len + 1);
+            if (len > 0 && !read_full(client_fd, args[i], len)) {
+                for (uint32_t j = 0; j <= i; j++) free(args[j]);
+                free(args);
+                goto fail_fds;
+            }
+            args[i][len] = '\0';
+        }
+        args[argc] = NULL;
+
+        /* Fork and exec */
+        pid_t child = fork();
+        if (child < 0) {
+            uint32_t exit_code = 1;
+            write_full(client_fd, &exit_code, sizeof(exit_code));
+            for (uint32_t i = 0; i < argc; i++) free(args[i]);
+            free(args);
+            goto fail_fds;
+        }
+
+        if (child == 0) {
+            /* Child: set up fds, identity, exec */
+            dup2(fds[0], STDIN_FILENO);
+            dup2(fds[1], STDOUT_FILENO);
+            dup2(fds[2], STDERR_FILENO);
+            close(fds[0]);
+            close(fds[1]);
+            close(fds[2]);
+            close(client_fd);
+
+            if (setgid(target_gid)) {
+                fprintf(stderr, "su: setgid(%u) failed: %s\n", target_gid, strerror(errno));
+                _exit(1);
+            }
+            if (setuid(target_uid)) {
+                fprintf(stderr, "su: setuid(%u) failed: %s\n", target_uid, strerror(errno));
+                _exit(1);
+            }
+
+            /* Reset environment */
+            setenv("PATH", _PATH_DEFPATH, 1);
+            unsetenv("IFS");
+            struct passwd* pw = getpwuid(target_uid);
+            if (pw) {
+                setenv("LOGNAME", pw->pw_name, 1);
+                setenv("USER", pw->pw_name, 1);
+            } else {
+                unsetenv("LOGNAME");
+                unsetenv("USER");
+            }
+
+            if (argc == 0) {
+                execl("/system/bin/sh", "sh", NULL);
+            } else {
+                execvp(args[0], args);
+            }
+            fprintf(stderr, "su: exec failed: %s\n", strerror(errno));
+            _exit(1);
+        }
+
+        /* Parent: wait for child, send exit code */
+        close(fds[0]);
+        close(fds[1]);
+        close(fds[2]);
+        for (uint32_t i = 0; i < argc; i++) free(args[i]);
+        free(args);
+
+        int status;
+        waitpid(child, &status, 0);
+        uint32_t exit_code = WIFEXITED(status) ? WEXITSTATUS(status) : 1;
+        write_full(client_fd, &exit_code, sizeof(exit_code));
+        close(client_fd);
+        return;
+    }
+
+fail_fds:
+    close(fds[0]);
+    close(fds[1]);
+    close(fds[2]);
+    {
+        uint32_t exit_code = 1;
+        write_full(client_fd, &exit_code, sizeof(exit_code));
+    }
+    close(client_fd);
+}
+
+static int run_daemon() {
+    /* Ignore SIGPIPE so we don't die on client disconnect */
+    signal(SIGPIPE, SIG_IGN);
+    /* Use default SIGCHLD so waitpid works correctly */
+    signal(SIGCHLD, SIG_DFL);
+
+    int sock = socket(AF_UNIX, SOCK_STREAM, 0);
+    if (sock < 0) error(1, errno, "socket");
+
+    struct sockaddr_un addr = {};
+    addr.sun_family = AF_UNIX;
+    strncpy(addr.sun_path, SU_SOCKET_PATH, sizeof(addr.sun_path) - 1);
+
+    unlink(SU_SOCKET_PATH);
+    if (bind(sock, (struct sockaddr*)&addr, sizeof(addr)) < 0)
+        error(1, errno, "bind %s", SU_SOCKET_PATH);
+
+    /* World-accessible so any app can connect; access control is via whitelist */
+    chmod(SU_SOCKET_PATH, 0666);
+
+    if (listen(sock, 8) < 0)
+        error(1, errno, "listen");
+
+    fprintf(stderr, "su: daemon listening on %s\n", SU_SOCKET_PATH);
+
+    while (true) {
+        int client = accept(sock, NULL, NULL);
+        if (client < 0) {
+            if (errno == EINTR) continue;
+            error(1, errno, "accept");
+        }
+
+        /* Fork a handler so long-running commands don't block new connections */
+        pid_t handler = fork();
+        if (handler == 0) {
+            close(sock);
+            handle_client(client);
+            _exit(0);
+        }
+        close(client);
+        /* Reap finished handlers (non-blocking) */
+        while (waitpid(-1, NULL, WNOHANG) > 0) {}
+    }
+}
