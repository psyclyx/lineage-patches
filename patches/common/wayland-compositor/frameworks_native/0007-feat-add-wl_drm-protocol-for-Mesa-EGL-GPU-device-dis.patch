diff --git a/services/surfaceflinger/Wayland/WaylandDrm.cpp b/services/surfaceflinger/Wayland/WaylandDrm.cpp
new file mode 100644
index 0000000000..7f6738c952
--- /dev/null
+++ b/services/surfaceflinger/Wayland/WaylandDrm.cpp
@@ -0,0 +1,129 @@
+/*
+ * Copyright (C) 2025 The LineageOS Project
+ *
+ * Licensed under the Apache License, Version 2.0 (the "License");
+ * you may not use this file except in compliance with the License.
+ * You may obtain a copy of the License at
+ *
+ *      http://www.apache.org/licenses/LICENSE-2.0
+ *
+ * Unless required by applicable law or agreed to in writing, software
+ * distributed under the License is distributed on an "AS IS" BASIS,
+ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+ * See the License for the specific language governing permissions and
+ * limitations under the License.
+ */
+
+#undef LOG_TAG
+#define LOG_TAG "WaylandDrm"
+
+#include "WaylandDrm.h"
+
+#include <algorithm>
+#include <drm_fourcc.h>
+#include <log/log.h>
+#include <unistd.h>
+
+#include "wayland-drm-server-protocol.h"
+
+namespace android {
+
+namespace {
+
+constexpr uint32_t kDrmVersion = 2;
+constexpr const char* kRenderNode = "/dev/dri/renderD128";
+
+// Formats advertised via wl_drm.format events.
+const uint32_t kFormats[] = {
+        DRM_FORMAT_ARGB8888,
+        DRM_FORMAT_XRGB8888,
+        DRM_FORMAT_ABGR8888,
+        DRM_FORMAT_XBGR8888,
+};
+
+} // anonymous namespace
+
+const struct wl_drm_interface WaylandDrm::kImpl = {
+        .authenticate = WaylandDrm::authenticate,
+        .create_buffer = WaylandDrm::createBuffer,
+        .create_planar_buffer = WaylandDrm::createPlanarBuffer,
+        .create_prime_buffer = WaylandDrm::createPrimeBuffer,
+};
+
+struct wl_global* WaylandDrm::createGlobal(struct wl_display* display,
+                                             WaylandCompositor* compositor) {
+    return wl_global_create(display, &wl_drm_interface, kDrmVersion, compositor, bind);
+}
+
+void WaylandDrm::bind(struct wl_client* client, void* data,
+                       uint32_t version, uint32_t id) {
+    int ver = static_cast<int>(std::min(version, kDrmVersion));
+    struct wl_resource* resource =
+            wl_resource_create(client, &wl_drm_interface, ver, id);
+    if (!resource) {
+        wl_client_post_no_memory(client);
+        return;
+    }
+    wl_resource_set_implementation(resource, &kImpl, data, nullptr);
+
+    // Tell the client which DRM device to open.
+    wl_drm_send_device(resource, kRenderNode);
+
+    // Advertise supported formats.
+    for (uint32_t fmt : kFormats) {
+        wl_drm_send_format(resource, fmt);
+    }
+
+    // Advertise PRIME (dmabuf fd) capability.
+    if (ver >= 2) {
+        wl_drm_send_capabilities(resource, WL_DRM_CAPABILITY_PRIME);
+    }
+
+    ALOGI("wl_drm bound (v%d), device=%s", ver, kRenderNode);
+}
+
+void WaylandDrm::authenticate(struct wl_client* /*client*/,
+                               struct wl_resource* resource,
+                               uint32_t /*id*/) {
+    // Render nodes (/dev/dri/renderDN) do not require DRM authentication.
+    // Just confirm success so the client proceeds.
+    wl_drm_send_authenticated(resource);
+}
+
+void WaylandDrm::createBuffer(struct wl_client* /*client*/,
+                               struct wl_resource* resource,
+                               uint32_t /*id*/, uint32_t /*name*/,
+                               int32_t /*width*/, int32_t /*height*/,
+                               uint32_t /*stride*/, uint32_t /*format*/) {
+    // GEM flink names are not supported — clients should use linux-dmabuf.
+    wl_resource_post_error(resource, WL_DRM_ERROR_INVALID_NAME,
+                           "wl_drm.create_buffer not supported, use linux-dmabuf");
+}
+
+void WaylandDrm::createPlanarBuffer(struct wl_client* /*client*/,
+                                     struct wl_resource* resource,
+                                     uint32_t /*id*/, uint32_t /*name*/,
+                                     int32_t /*width*/, int32_t /*height*/,
+                                     uint32_t /*format*/,
+                                     int32_t /*offset0*/, int32_t /*stride0*/,
+                                     int32_t /*offset1*/, int32_t /*stride1*/,
+                                     int32_t /*offset2*/, int32_t /*stride2*/) {
+    wl_resource_post_error(resource, WL_DRM_ERROR_INVALID_NAME,
+                           "wl_drm.create_planar_buffer not supported, use linux-dmabuf");
+}
+
+void WaylandDrm::createPrimeBuffer(struct wl_client* /*client*/,
+                                    struct wl_resource* resource,
+                                    uint32_t /*id*/, int32_t fd,
+                                    int32_t /*width*/, int32_t /*height*/,
+                                    uint32_t /*format*/,
+                                    int32_t /*offset0*/, int32_t /*stride0*/,
+                                    int32_t /*offset1*/, int32_t /*stride1*/,
+                                    int32_t /*offset2*/, int32_t /*stride2*/) {
+    // Close the fd the client sent — we won't use it.
+    close(fd);
+    wl_resource_post_error(resource, WL_DRM_ERROR_INVALID_NAME,
+                           "wl_drm.create_prime_buffer not supported, use linux-dmabuf");
+}
+
+} // namespace android
