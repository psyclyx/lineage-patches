<?xml version="1.0" encoding="UTF-8"?>
<manifest>

  <remote name="psyclyx"
          fetch="https://github.com/psyclyx" />

  <!-- su-whitelist: root access control via whitelist -->

  <remove-project name="LineageOS/android_vendor_lineage" />
  <project path="vendor/lineage" name="android_vendor_lineage"
           remote="psyclyx" revision="su-whitelist" />

  <remove-project name="LineageOS/android_system_extras" />
  <project path="system/extras" name="android_system_extras"
           remote="psyclyx" revision="su-whitelist" groups="pdk" />

  <remove-project name="LineageOS/android_packages_apps_Settings" />
  <project path="packages/apps/Settings" name="android_packages_apps_Settings"
           remote="psyclyx" revision="su-whitelist" groups="pdk-fs,pdk-cw-tvc,sysui-studio" />

  <!-- wayland-compositor: embedded Wayland compositor in SurfaceFlinger -->

  <remove-project name="platform/external/wayland" />
  <project path="external/wayland" name="android_external_wayland"
           remote="psyclyx" revision="wayland-compositor" groups="pdk" />

  <remove-project name="LineageOS/android_frameworks_native" />
  <project path="frameworks/native" name="android_frameworks_native"
           remote="psyclyx" revision="wayland-compositor" groups="pdk" />

  <!-- su-whitelist + wayland-compositor (shared repo, both features) -->

  <remove-project name="LineageOS/android_system_sepolicy" />
  <project path="system/sepolicy" name="android_system_sepolicy"
           remote="psyclyx" revision="su-whitelist+wayland-compositor" groups="pdk" />

  <!-- device/dre: OnePlus Nord N200 device-specific changes -->

  <remove-project name="LineageOS/android_device_oneplus_dre" />
  <project path="device/oneplus/dre" name="android_device_oneplus_dre"
           remote="psyclyx" revision="dre" />

  <remove-project name="LineageOS/android_kernel_oneplus_sm4350" />
  <project path="kernel/oneplus/sm4350" name="android_kernel_oneplus_sm4350"
           remote="psyclyx" revision="dre" />

  <!-- device/dre build fixes: sepolicy workarounds -->

  <remove-project name="LineageOS/android_device_qcom_sepolicy" />
  <project path="device/qcom/sepolicy" name="android_device_qcom_sepolicy"
           remote="psyclyx" revision="dre" />

  <remove-project name="LineageOS/android_device_qcom_sepolicy_vndr" />
  <project path="device/qcom/sepolicy_vndr/legacy-um" name="android_device_qcom_sepolicy_vndr"
           remote="psyclyx" revision="dre" />

</manifest>
